{
  "name": "lockick",
  "displayName": "LocKick",
  "description": "The minimalist VS Code client for local LLMs.",
  "version": "0.1.0",
  "publisher": "maxgf",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lockick-explorer",
          "title": "LocKick",
          "icon": "resources/icon.png"
        }
      ],
      "panel": [
        {
          "id": "lockick-panel",
          "title": "LocKick",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "lockick-explorer": [
        {
          "type": "webview",
          "id": "lockick.chatView",
          "name": "Chat",
          "icon": "resources/icon.png"
        }
      ],
      "lockick-panel": [
        {
          "type": "webview",
          "id": "lockick.agentLog",
          "name": "Agent Log",
          "icon": "resources/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "lockick.askAboutSelection",
        "title": "LocKick: Ask About Selection"
      },
      {
        "command": "lockick.testConnection",
        "title": "LocKick: Test Connection"
      },
      {
        "command": "lockick.openAgentLog",
        "title": "LocKick: Open Agent Log"
      }
    ],
    "configuration": {
      "title": "LocKick",
      "properties": {
        "lockick.serverUrl": {
          "type": "string",
          "default": "http://localhost:1234/v1",
          "description": "LM Studio / OpenAI-compatible server URL."
        },
        "lockick.modelName": {
          "type": "string",
          "default": "default",
          "description": "Name of the model to use."
        },
        "lockick.inlineCompletionsEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI-powered inline code completions."
        },
        "lockick.completionMaxTokens": {
          "type": "number",
          "default": 64,
          "description": "Maximum tokens to generate for inline completions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
